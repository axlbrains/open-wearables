project_id = "your-prod-project-id"
region     = "europe-west1"

name_prefix = "open-wearables"

labels = {
  app         = "open-wearables"
  environment = "prod"
  managed_by  = "terraform"
}

artifact_registry_repository_id = "open-wearables-prod"

create_secrets = true
secret_names = [
  "open-wearables-prod-secret-key",
  "open-wearables-prod-db-password",
  "open-wearables-prod-resend-api-key",
]

create_network     = true
create_cloud_sql   = true
create_memorystore = true

enable_backend_api_service    = true
enable_worker_service         = true
enable_backend_init_job       = true
enable_frontend_service       = true
enable_cloud_tasks_dispatch   = false
create_default_scheduler_jobs = true

cloud_sql_db_name     = "open-wearables"
cloud_sql_db_user     = "open_wearables"
cloud_sql_db_password = "replace-me"

backend_image  = "europe-west1-docker.pkg.dev/your-prod-project-id/open-wearables-prod/backend:latest"
frontend_image = "europe-west1-docker.pkg.dev/your-prod-project-id/open-wearables-prod/frontend:latest"

worker_service_base_url = "https://worker.example.run.app"

backend_api_env = {
  ENVIRONMENT  = "production"
  SECRET_KEY   = "replace-me"
  CORS_ORIGINS = "https://frontend.example.com"
}

backend_worker_env = {
  ENVIRONMENT = "production"
  SECRET_KEY  = "replace-me"
}

backend_init_env = {
  ENVIRONMENT = "production"
  SECRET_KEY  = "replace-me"
}

frontend_env = {
  VITE_API_URL = "https://api.example.com"
}

scheduler_jobs = {
  sync-all-users = {
    description                = "Run periodic vendor sync fan-out"
    schedule                   = "0 * * * *"
    time_zone                  = "Etc/UTC"
    target_url                 = "https://worker.example.run.app/tasks/sync-all-users"
    oidc_service_account_email = "open-wearables-prod-scheduler@your-prod-project-id.iam.gserviceaccount.com"
    audience                   = "https://worker.example.run.app"
    headers = {
      Content-Type = "application/json"
    }
    body = "{\"source\":\"cloud-scheduler\"}"
  }
  finalize-stale-sleeps = {
    description                = "Finalize stale sleep sessions"
    schedule                   = "15 * * * *"
    time_zone                  = "Etc/UTC"
    target_url                 = "https://worker.example.run.app/tasks/finalize-stale-sleeps"
    oidc_service_account_email = "open-wearables-prod-scheduler@your-prod-project-id.iam.gserviceaccount.com"
    audience                   = "https://worker.example.run.app"
    headers = {
      Content-Type = "application/json"
    }
    body = "{\"source\":\"cloud-scheduler\"}"
  }
}
